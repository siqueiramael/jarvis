# ============================================
# JARVIS v2.0 - Configuration Template
# ============================================

# -------- SERVER --------
PORT=3000
NODE_ENV=production

# -------- LM STUDIO (Windows PC via Tailscale) --------
# OpenAI-compatible API endpoint for chat/LLM
# Format: http://[Windows-Tailscale-IP]:1234/v1
OPENAI_API_BASE=http://100.112.73.46:1234/v1

# LLM Model to use (must be loaded in LM Studio)
LM_STUDIO_MODEL=openhermes-2.5-neural-chat-7b-v3-2-7b

# -------- WHISPER GPU SERVER (Windows PC - Phase 6) --------
# FastAPI endpoint for GPU-accelerated STT (Speech-to-Text)
# Format: http://[Windows-Tailscale-IP]:8001
# Leave empty to fallback to CPU whisper.cpp
WHISPER_URL=http://100.112.73.46:8001

# -------- OBSIDIAN KNOWLEDGE BASE --------
# Git repository URL for Obsidian vault syncing
GIT_REPO=https://github.com/YOUR_USERNAME/jarvis-brain.git
GIT_BRANCH=master

# -------- VOICE (TTS) --------
# Piper runs locally in the Docker container
PIPER_MODEL=pt_BR-faber-medium

# -------- DOCKER VOLUMES --------
# These paths are mounted in docker-compose.yml
# OBSIDIAN_VAULT=/app/data/obsidian-vault
# LOGS_DIR=/app/logs

# ============================================
# NOTES FOR SETUP
# ============================================
# 
# 1. LM STUDIO Setup:
#    - Install LM Studio on Windows PC
#    - Load model (e.g., OpenHermes 7B)
#    - Enable "Serve on Network" or set --bind 0.0.0.0
#    - Confirm accessible at http://[Windows-IP]:1234/v1/models
#
# 2. WHISPER GPU Setup (Phase 6):
#    - Install faster-whisper: pip install faster-whisper
#    - Create whisper_server.py with FastAPI wrapper
#    - Run: uvicorn whisper_server:app --host 0.0.0.0 --port 8001
#    - Test: curl http://[Windows-IP]:8001/transcribe
#
# 3. NETWORKING:
#    - Use Tailscale to bridge VPS ↔ Windows
#    - VPS Tailscale IP: 100.114.78.91
#    - Windows Tailscale IP: 100.112.73.46
#    - Configure firewall rules if needed
#
# 4. OBSIDIAN:
#    - Create public GitHub repo for vault
#    - Clone locally: git clone [GIT_REPO]
#    - Sync runs automatically every 5 minutes
#
# ============================================
